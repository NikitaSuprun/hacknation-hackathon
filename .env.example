# Databricks Free Edition workspace (see docs/runbooks/databricks.md).
# Service-principal M2M OAuth credentials — never commit the real .env.
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<oauth-secret>
DATABRICKS_WAREHOUSE_ID=<serverless-sql-warehouse-id>
# Optional: reroute every ai_query completion to the one Claude endpoint
# your workspace serves (poe smoke lists them; Free Edition often has
# only databricks-claude-opus-4-8).
DATABRICKS_LLM_ENDPOINT=

# Scrapers (WS-A/WS-B). Contact email goes into every User-Agent per API etiquette.
SCRAPER_CONTACT_EMAIL=<you@example.com>
# GitHub scraper — per-dev classic PAT with public_repo scope (avoids shared secondary limits).
GITHUB_TOKEN=<per-dev-pat>
# OpenAlex free API key (required since 2026 — polite pool retired); request Day 0.
OPENALEX_API_KEY=<openalex-key>
# Optional Semantic Scholar key; the s2 command is a no-op without it.
S2_API_KEY=

# Anthropic API key — Stage-B deep-dive web_search and the ER adjudication
# Batches fallback (the primary LLM path is in-warehouse ai_query).
ANTHROPIC_API_KEY=
