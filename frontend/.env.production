# Deployed build: real /v1 API, served same-origin by the Starlette app.
# Empty VITE_API_BASE means same-origin (see src/lib/auth.ts apiBase), which is
# what lets us skip CORS entirely — app/api.py has no CORS middleware.
VITE_DATA_MODE=live
VITE_API_BASE=
# Jurors must not be able to flip to mock data via ?demo=1.
VITE_ALLOW_MODE_TOGGLE=false
