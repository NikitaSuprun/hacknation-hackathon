{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealflow.internal/schemas/ideal.schema.json",
  "title": "IdealCandidateProfile",
  "description": "gold.ideal_candidate.profile_json: the editable structured profile; ordinal prestige lives in institution_score, embeddings do domain-fit only.",
  "type": "object",
  "required": ["schema_version", "numeric_features"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "narrative": { "type": ["string", "null"] },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution"],
        "properties": {
          "institution": { "type": "string", "minLength": 1 },
          "level": { "type": ["string", "null"] },
          "field": { "type": ["string", "null"] }
        }
      }
    },
    "sectors": { "type": "array", "items": { "type": "string" } },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "numeric_features": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "feature_weights": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    }
  }
}
